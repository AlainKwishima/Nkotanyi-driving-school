{
  "expo": {
    "name": "Ibyapa",
    "slug": "nkotanyi",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "nkotanyi",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fbf8fd"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nkotanyi.app",
      "infoPlist": {
        "UIRequiresFullScreen": false
      }
    },
    "android": {
      "package": "com.nkotanyi.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fbf8fd"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "Ibyapa",
      "shortName": "Ibyapa",
      "lang": "en",
      "description": "Road safety learning and driving exam preparation.",
      "themeColor": "#4A78D0",
      "backgroundColor": "#fbf8fd",
      "display": "standalone",
      "orientation": "any"
    },
    "plugins": ["expo-font"]
  }
}
